{
  "name": "@uecsio/page-cache-api",
  "version": "1.0.0",
  "description": "A NestJS module for caching pages from SQL to MongoDB",
  "keywords": [
    "nestjs",
    "pages",
    "cache",
    "mongodb",
    "mongoose",
    "sync"
  ],
  "author": "Dmytro Morozov <morosovdmitry@gmail.com>",
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/**/*"
  ],
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "prepublishOnly": "npm run build",
    "clean": "rimraf dist"
  },
  "peerDependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/typeorm": "^11.0.0",
    "@nestjs/mongoose": "^11.0.0",
    "@uecsio/pages-api": "^2.0.0",
    "@uecsio/cache-api": "file:../cache-api",
    "@uecsio/utils-api": "^0.0.2",
    "typeorm": "^0.3.0",
    "mongoose": "^8.0.0",
    "bull": "^4.16.5",
    "@nestjs/bull": "^11.0.4"
  },
  "devDependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@nestjs/typeorm": "^11.0.0",
    "@nestjs/mongoose": "^11.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.0.0",
    "@uecsio/pages-api": "file:../pages-nestjs",
    "@uecsio/utils": "file:../utils",
    "jest": "^30.0.0",
    "ts-jest": "^29.2.5",
    "typescript": "^5.7.3",
    "typeorm": "^0.3.26",
    "mongoose": "^8.0.0",
    "rimraf": "^5.0.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
